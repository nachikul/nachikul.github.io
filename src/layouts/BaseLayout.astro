---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/favicon.svg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Nachiket Kulkarni</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Nachiket Kulkarni`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | Nachiket Kulkarni`} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <nav class="nav-container">
        <a href="/" class="nav-brand">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="32" height="32" aria-hidden="true">
            <rect width="40" height="40" rx="8" fill="var(--accent)"/>
            <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle"
                  font-family="'JetBrains Mono', monospace" font-size="16" font-weight="700" fill="#fff">NK</text>
          </svg>
          <span>Nachiket</span>
        </a>
        <ul class="nav-links">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
        <div class="nav-actions">
          <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" title="Toggle theme">
            <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
          <button class="hamburger" id="hamburger" aria-label="Open menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-container">
        <p class="footer-text">
          &copy; {new Date().getFullYear()} Nachiket Kulkarni &mdash; Senior DevOps / Platform Engineer
        </p>
        <div class="footer-links">
          <a href="https://github.com/nachikul" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/nkulkarni9493" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:nachikul1993@gmail.com">Email</a>
        </div>
      </div>
    </footer>

    <script>
      const html = document.documentElement;
      const btn = document.getElementById('theme-toggle');
      const hamburger = document.getElementById('hamburger');
      const navLinks = document.querySelector('.nav-links');

      // Restore saved theme
      const saved = localStorage.getItem('theme');
      if (saved) html.setAttribute('data-theme', saved);

      btn?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      hamburger?.addEventListener('click', () => {
        navLinks?.classList.toggle('open');
        hamburger.classList.toggle('active');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ── CSS custom properties ── */
  :root {
    --accent: #0d9488;
    --accent-light: #14b8a6;
    --accent-dim: rgba(13, 148, 136, 0.15);

    /* Dark theme (default) */
    --bg: #0f172a;
    --bg-card: #1e293b;
    --bg-card-hover: #253347;
    --border: #334155;
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --text-heading: #f8fafc;
    --shadow: 0 4px 24px rgba(0,0,0,0.4);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.3);
  }

  [data-theme="light"] {
    --bg: #f8fafc;
    --bg-card: #ffffff;
    --bg-card-hover: #f1f5f9;
    --border: #e2e8f0;
    --text: #334155;
    --text-muted: #64748b;
    --text-heading: #0f172a;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
    --shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
  }

  /* ── Reset & base ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    transition: background 0.25s, color 0.25s;
  }

  h1, h2, h3, h4 {
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-heading);
    line-height: 1.2;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--accent-light); }

  img { max-width: 100%; display: block; }

  main { flex: 1; }

  code, pre {
    font-family: 'JetBrains Mono', monospace;
  }

  /* ── Header / Nav ── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .nav-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-heading);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .nav-brand:hover { color: var(--accent); }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--accent);
    background: var(--accent-dim);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 1rem;
  }

  .theme-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-muted);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .theme-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

  [data-theme="dark"] .sun-icon { display: block; }
  [data-theme="dark"] .moon-icon { display: none; }
  [data-theme="light"] .sun-icon { display: none; }
  [data-theme="light"] .moon-icon { display: block; }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-text { color: var(--text-muted); font-size: 0.875rem; }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--accent); }

  /* ── Shared section styles ── */
  .page-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }

  .section-label {
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
    color: var(--text-heading);
  }

  .section-desc {
    color: var(--text-muted);
    max-width: 60ch;
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hamburger { display: flex; }

    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 1rem 1.5rem;
      gap: 0.25rem;
    }
    .nav-links.open { display: flex; }
    .nav-links li { width: 100%; }
    .nav-link { display: block; width: 100%; }

    .footer-container { flex-direction: column; text-align: center; }
    .footer-links { justify-content: center; }
  }
</style>
