---
import BaseLayout from '../layouts/BaseLayout.astro';
import experience from '../data/experience.json';
---

<BaseLayout
  title="Experience"
  description="Nachiket Kulkarni's professional experience — Principal Platform Engineer at Autodesk, plus NICE, Coupa Software, TIBCO Software. Close to 10 years in DevOps and platform engineering."
>
  <section class="page-section">
    <p class="section-label">Career</p>
    <h1 class="section-title">Work Experience</h1>
    <p class="section-desc">
      Close to 10 years across enterprise software, SaaS, and platform engineering — from QA automation
      to leading cloud infrastructure at scale.
    </p>

    <ol class="timeline">
      {experience.map((job, i) => (
        <li class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-dot" />
            {i < experience.length - 1 && <span class="timeline-line" />}
          </div>
          <div class="timeline-card">
            <div class="timeline-header">
              <div class="job-heading">
                <span class="company-badge" aria-hidden="true">{job.company.charAt(0)}</span>
                <div>
                  <h2 class="job-company">{job.company}</h2>
                  <h3 class="job-role">{job.role}</h3>
                </div>
              </div>
              <div class="job-meta">
                <span class="job-period-row">
                  <span class="job-period">{job.period}</span>
                  {i === 0 && <span class="current-pill">Current</span>}
                </span>
                <span class="job-location">{job.location}</span>
              </div>
            </div>
            <ul class="job-highlights">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .timeline {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 0 1.5rem;
  }

  /* Marker column */
  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 1.4rem;
  }

  .timeline-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-line {
    width: 2px;
    flex: 1;
    background: var(--border);
    margin-top: 4px;
    min-height: 40px;
  }

  /* Card */
  .timeline-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem 1.75rem;
    margin-bottom: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .timeline-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .job-heading {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .company-badge {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent-dim);
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .job-company {
    font-size: 1.2rem;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }

  .job-role {
    font-size: 1rem;
    color: var(--text-heading);
    font-weight: 500;
    font-family: 'Inter', sans-serif;
  }

  .job-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .job-period-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .job-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    white-space: nowrap;
  }

  .current-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 15%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    white-space: nowrap;
  }

  .job-location {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .job-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .job-highlights li {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    padding-left: 1.25rem;
    position: relative;
  }

  .job-highlights li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.75rem;
    top: 0.25rem;
  }

  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 32px 1fr;
      gap: 0 1rem;
    }
    .job-meta { align-items: flex-start; }
    .timeline-header { flex-direction: column; }
  }
</style>
