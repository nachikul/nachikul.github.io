---
import Layout from '../layouts/Layout.astro';
import experience from '../data/experience.json';
---

<Layout
  title="Experience — Nachiket Kulkarni"
  description="Work history of Nachiket Kulkarni — Senior DevOps / Platform Engineer. Autodesk, NICE, Coupa Software, TIBCO."
>
  <div class="page">
    <h1 class="page-title">Experience</h1>
    <p class="page-subtitle">8+ years building cloud infrastructure and DevOps platforms</p>

    <div class="timeline">
      {experience.map((job, i) => (
        <div class="timeline-item">
          <div class="timeline-marker">
            <div class="marker-dot" />
            {i < experience.length - 1 && <div class="marker-line" />}
          </div>
          <div class="timeline-content">
            <div class="job-header">
              <div>
                <h2 class="job-role">{job.role}</h2>
                <p class="job-company">{job.company}</p>
              </div>
              <div class="job-meta">
                <span class="job-period">{job.period}</span>
                <span class="job-location">{job.location}</span>
              </div>
            </div>
            <p class="job-description">{job.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 0.35rem;
  }

  .marker-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
    flex-shrink: 0;
  }

  .marker-line {
    width: 2px;
    flex: 1;
    background: var(--border);
    min-height: 2rem;
    margin: 0.4rem 0;
  }

  .timeline-content {
    padding-bottom: 2.5rem;
    flex: 1;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .job-role {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    font-family: var(--font-mono);
    margin-bottom: 0.15rem;
  }

  .job-company {
    color: var(--accent-light);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .job-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
  }

  .job-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .job-location {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .job-description {
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  @media (max-width: 540px) {
    .job-header {
      flex-direction: column;
    }
    .job-meta {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>
