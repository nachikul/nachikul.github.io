---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Nachiket Kulkarni — Principal Platform Engineer with close to 10 years of experience building cloud infrastructure, internal platforms, and MLOps systems."
>
  <section class="hero">
    <div class="hero-inner">
      <div class="avatar-ring">
        <span class="avatar-initials">NK</span>
      </div>
      <p class="hero-label">👋 Hello, I'm</p>
      <h1 class="hero-name">Nachiket Kulkarni</h1>
      <h2 class="hero-role">Principal Platform Engineer</h2>
      <p class="hero-summary">
        Building resilient cloud infrastructure, internal developer platforms, and MLOps systems at scale.
        Currently at <strong>Autodesk</strong> in Pune, India.
      </p>
      <div class="hero-cta">
        <a href="/projects" class="btn btn-primary">View Projects</a>
        <a href="/contact" class="btn btn-outline">Contact Me</a>
      </div>
      <div class="hero-badges">
        <span class="badge">Platform Engineering</span>
        <span class="badge">AWS</span>
        <span class="badge">Kubernetes</span>
        <span class="badge">Terraform</span>
        <span class="badge">MLOps</span>
        <span class="badge">GitOps</span>
      </div>
    </div>
    <div class="hero-graphic" aria-hidden="true">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
          <span class="terminal-title">nachikul ~ terminal</span>
        </div>
        <div class="terminal-body">
          <p><span class="prompt">$</span> <span class="cmd">kubectl get pods -n production</span></p>
          <p class="out">NAME&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;READY&nbsp;&nbsp;STATUS</p>
          <p class="out">api-7d9f8b-xk2p9&nbsp;&nbsp;&nbsp;1/1&nbsp;&nbsp;&nbsp;&nbsp;Running</p>
          <p class="out">worker-5c6d7-m3q1r&nbsp;1/1&nbsp;&nbsp;&nbsp;&nbsp;Running</p>
          <p><span class="prompt">$</span> <span class="cmd">terraform apply --auto-approve</span></p>
          <p class="out success">Apply complete! Resources: 12 added.</p>
          <p><span class="prompt">$</span> <span class="cursor">█</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="highlights">
    <div class="highlights-grid">
      <div class="highlight-card">
        <span class="highlight-num">10</span>
        <span class="highlight-label">Years of Experience</span>
      </div>
      <div class="highlight-card">
        <span class="highlight-num">Principal</span>
        <span class="highlight-label">Platform Leadership</span>
      </div>
      <div class="highlight-card">
        <span class="highlight-num">MS</span>
        <span class="highlight-label">CS — Georgia Tech</span>
      </div>
      <div class="highlight-card">
        <span class="highlight-num highlight-num-alt">∞</span>
        <span class="highlight-label">Systems Improved</span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    max-width: 1100px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: calc(100vh - 64px - 6rem);
  }

  .avatar-ring {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: conic-gradient(var(--accent), var(--accent-2), var(--accent));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3px;
    margin-bottom: 1.5rem;
  }

  .avatar-initials {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--text-heading);
  }

  .hero-label {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    background: linear-gradient(135deg, var(--text-heading), var(--accent-light));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
  }

  .hero-role {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--accent);
    font-weight: 400;
    margin-bottom: 1.5rem;
  }

  .divider { color: var(--text-muted); margin: 0 0.3rem; }

  .hero-summary {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 50ch;
    margin-bottom: 2rem;
    line-height: 1.75;
  }
  .hero-summary strong { color: var(--accent); }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    cursor: pointer;
    border: 2px solid transparent;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn-primary:hover { background: var(--accent-light); border-color: var(--accent-light); color: #fff; }

  .btn-outline {
    background: transparent;
    color: var(--accent);
    border-color: var(--accent);
  }
  .btn-outline:hover { background: var(--accent-dim); color: var(--accent-light); }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    padding: 0.25rem 0.7rem;
    border-radius: 99px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(99,102,241,0.3);
    font-weight: 600;
  }

  /* ── Terminal ── */
  .terminal {
    background: var(--terminal-bg);
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: var(--shadow);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
  }

  .terminal-bar {
    background: var(--terminal-bar-bg);
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .terminal-title {
    color: var(--text-muted);
    font-size: 0.75rem;
    margin-left: 0.5rem;
  }

  .terminal-body {
    padding: 1.2rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .cmd { color: #e2e8f0; }
  .out { color: #64748b; padding-left: 1.2rem; }
  .out.success { color: #28c840; }
  .cursor { animation: blink 1s step-end infinite; color: var(--accent); }

  @keyframes blink { 50% { opacity: 0; } }

  /* ── Highlights ── */
  .highlights {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .highlights-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .highlight-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .highlight-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .highlight-num-alt { color: var(--accent-2); }

  .highlight-label {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 4rem;
      min-height: auto;
      gap: 3rem;
    }
    .highlights-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .highlights-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .hero-cta { flex-direction: column; }
    .btn { justify-content: center; }
  }
</style>
