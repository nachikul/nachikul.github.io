---
import BaseLayout from '../layouts/BaseLayout.astro';
import projects from '../data/projects.json';
---

<BaseLayout
  title="Projects"
  description="Open-source projects by Nachiket Kulkarni — AI resume summariser, Kubernetes/EKS deployments, CLI tools, and more."
>
  <section class="page-section">
    <p class="section-label">Open Source</p>
    <h1 class="section-title">Projects</h1>
    <p class="section-desc">
      A selection of personal and open-source projects. Each one tackles a real problem
      I've encountered in DevOps, platform engineering, or daily developer workflows.
    </p>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-top">
            <div class="project-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            </div>
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="project-link"
              aria-label={`View ${project.name} on GitHub`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
          <h2 class="project-name">
            <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
          </h2>
          <p class="project-desc">{project.description}</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>

    <div class="more-cta">
      <p class="more-text">More projects on GitHub</p>
      <a
        href="https://github.com/nachikul"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
      >
        View GitHub Profile →
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
    box-shadow: var(--shadow-sm);
  }
  .project-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    border: 1px solid rgba(13,148,136,0.2);
  }

  .project-link {
    color: var(--text-muted);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }
  .project-link:hover { color: var(--accent); background: var(--accent-dim); }

  .project-name {
    font-size: 1.15rem;
    color: var(--text-heading);
  }
  .project-name a {
    color: inherit;
    transition: color 0.2s;
  }
  .project-name a:hover { color: var(--accent); }

  .project-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(13,148,136,0.25);
    font-weight: 600;
  }

  .more-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem 0;
  }

  .more-text {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    background: transparent;
    color: var(--accent);
    border: 2px solid var(--accent);
    transition: all 0.2s;
  }
  .btn-outline:hover { background: var(--accent-dim); color: var(--accent-light); }
</style>
