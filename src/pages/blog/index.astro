---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: null,
    url: 'https://substack.com/@nachikul/note/c-276293690?r=8w7cv&utm_source=notes-share-action&utm_medium=web',
    title: 'I Built an AI World Cup Predictor Because My Fantasy Team Was Embarrassing Me',
    description:
      'Fantasy Football, Spec Driven Development, and a $5 AI budget. How I used the World Cup as a forcing function to learn something new — and shipped a live Claude-powered match predictor.',
    date: '2026-06-15',
    dateLabel: 'June 15, 2026',
    readTime: '6 min read',
    tags: ['AI', 'SDD', 'World Cup', 'Side Project', 'Anthropic'],
    external: true,
  },
  {
    slug: 'operators-vs-gitops',
    url: null,
    title: "Operators vs. GitOps: You've Been Asking the Wrong Question",
    description:
      'Two reconciliation loops, one control plane — and why the smartest platform teams stopped picking a side.',
    date: '2026-06-01',
    dateLabel: 'June 1, 2026',
    readTime: '8 min read',
    tags: ['Kubernetes', 'GitOps', 'Operators', 'Platform Engineering'],
    external: false,
  },
];
---

<BaseLayout
  title="Blog"
  description="DevOps, platform engineering, MLOps, and cloud infrastructure insights from Nachiket Kulkarni."
>
  <section class="page-section blog-page">
    <p class="section-label">Writing</p>
    <h1 class="section-title">Blog</h1>
    <p class="section-desc">
      Thoughts on platform engineering, GitOps, Kubernetes, and building reliable infrastructure at scale.
    </p>

    <div class="posts-list">
      {posts.map((post) => (
        <a
          href={post.external ? post.url : `/blog/${post.slug}`}
          target={post.external ? '_blank' : '_self'}
          rel={post.external ? 'noopener noreferrer' : undefined}
          class="post-card"
        >
          <div class="post-card-meta">
            <time datetime={post.date}>{post.dateLabel}</time>
            <span class="meta-sep">·</span>
            <span>{post.readTime}</span>
            {post.external && <span class="external-badge">Substack</span>}
          </div>
          <h2 class="post-card-title">{post.title}</h2>
          <p class="post-card-desc">{post.description}</p>
          <div class="post-card-tags">
            {post.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <span class="read-more">{post.external ? 'Read on Substack →' : 'Read post →'}</span>
        </a>
      ))}
    </div>

    <div class="notify-section">
      <p class="notify-text">
        Also on
        <a href="https://nachikul.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>
        · Follow me on
        <a href="https://www.linkedin.com/in/nkulkarni9493" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        or
        <a href="https://github.com/nachikul" target="_blank" rel="noopener noreferrer">GitHub</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page { max-width: 760px; }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .post-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    box-shadow: var(--shadow-sm);
  }
  .post-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .meta-sep { opacity: 0.5; }

  .external-badge {
    font-size: 0.68rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(99, 102, 241, 0.25);
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }

  .post-card-title {
    font-size: 1.25rem;
    color: var(--text-heading);
    margin-bottom: 0.6rem;
    line-height: 1.3;
    transition: color 0.2s;
  }
  .post-card:hover .post-card-title { color: var(--accent); }

  .post-card-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.72rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(99, 102, 241, 0.25);
    padding: 0.15rem 0.55rem;
    border-radius: 4px;
  }

  .read-more {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
  }

  .notify-section {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  .notify-text {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }
</style>
