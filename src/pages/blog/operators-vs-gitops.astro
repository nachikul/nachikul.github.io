    color: var(--text-heading);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .post-subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .meta-sep { opacity: 0.5; }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(13, 148, 136, 0.25);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  /* ── Prose ── */
