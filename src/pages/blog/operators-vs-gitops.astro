    color: var(--text);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .post-body .lead {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

