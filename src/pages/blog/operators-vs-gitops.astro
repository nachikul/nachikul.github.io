    font-size: 1.35rem;
    color: var(--text-heading);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-body p {
    margin-bottom: 1.25rem;
  }

  .post-body ul,
  .post-body ol {
    margin: 0 0 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-body li {
    line-height: 1.7;
  }

  .post-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    color: var(--accent-light);
    background: var(--accent-dim);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

