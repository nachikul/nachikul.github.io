---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactLinks = [
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/nkulkarni9493',
    href: 'https://www.linkedin.com/in/nkulkarni9493',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/nachikul',
    href: 'https://github.com/nachikul',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
    external: true,
  },
  {
    label: 'Email',
    value: 'nachikul1993@gmail.com',
    href: 'mailto:nachikul1993@gmail.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    external: false,
  },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Nachiket Kulkarni — Senior DevOps / Platform Engineer. Available on LinkedIn, GitHub, and email."
>
  <section class="page-section contact-page">
    <p class="section-label">Get In Touch</p>
    <h1 class="section-title">Contact</h1>
    <p class="section-desc">
      I'm always open to interesting conversations about platform engineering, DevOps,
      MLOps, or just a good tech discussion. Reach out through any of the channels below.
    </p>

    <div class="contact-grid">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          class="contact-card"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          <span class="contact-icon" set:html={link.icon} />
          <div class="contact-info">
            <span class="contact-label">{link.label}</span>
            <span class="contact-value">{link.value}</span>
          </div>
          <svg class="contact-arrow" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      ))}
    </div>

    <div class="availability-card">
      <div class="avail-dot" aria-hidden="true" />
      <div>
        <p class="avail-heading">Currently at Autodesk</p>
        <p class="avail-text">
          Open to conversations about interesting roles, collaborations, or speaking opportunities
          in the DevOps / Platform Engineering space.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page { max-width: 700px; }

  .contact-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    box-shadow: var(--shadow-sm);
  }
  .contact-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateX(4px);
    color: var(--text);
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: var(--accent-dim);
    border: 1px solid rgba(13,148,136,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .contact-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-heading);
  }

  .contact-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .contact-card:hover .contact-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  .availability-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 12px 12px 0;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .avail-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
    flex-shrink: 0;
    margin-top: 5px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
    50% { box-shadow: 0 0 0 6px rgba(34,197,94,0.1); }
  }

  .avail-heading {
    font-weight: 600;
    color: var(--text-heading);
    font-size: 0.95rem;
    margin-bottom: 0.35rem;
  }

  .avail-text {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
  }
</style>
